    <!-- Setup Wizard -->
    <sys:String x:Key="Wizard_WindowTitle" xmlns:sys="clr-namespace:System;assembly=mscorlib">Kreator konfiguracji — Kaption</sys:String>
    <sys:String x:Key="Wizard_Step1_Title" xmlns:sys="clr-namespace:System;assembly=mscorlib">Wybierz obszar dialogu</sys:String>
    <sys:String x:Key="Wizard_Step1_Subtitle" xmlns:sys="clr-namespace:System;assembly=mscorlib">Wskaż miejsce, w którym pojawiają się kwestie NPC</sys:String>
    <sys:String x:Key="Wizard_Step1_TipPrefix" xmlns:sys="clr-namespace:System;assembly=mscorlib">Wskazówka:</sys:String>
    <sys:String x:Key="Wizard_Step1_TipBody" xmlns:sys="clr-namespace:System;assembly=mscorlib">Rozpocznij zadanie z NPC, który mówi w 3+ liniach, i narysuj obszar nieco większy niż najdłuższa z nich. Krótkie dialogi i tak się zmieszczą, a długie nie zostaną przycięte.</sys:String>
    <sys:String x:Key="Wizard_Step1_BorderlessPrefix" xmlns:sys="clr-namespace:System;assembly=mscorlib">Tryb wyświetlania:</sys:String>
    <sys:String x:Key="Wizard_Step1_BorderlessBody" xmlns:sys="clr-namespace:System;assembly=mscorlib">Włącz w grze tryb „bez ramki” albo okienkowy (Alt+Enter w grze). Pełny ekran sprawia, że napis miga — z tego samego powodu nie radzą sobie tam też nakładki Discorda i Steama.</sys:String>
    <sys:String x:Key="Wizard_Step1_GuidePrefix" xmlns:sys="clr-namespace:System;assembly=mscorlib">Wolisz przewodnik ze zrzutami ekranu? </sys:String>
    <sys:String x:Key="Wizard_Step1_GuideLink" xmlns:sys="clr-namespace:System;assembly=mscorlib">Zobacz pełny poradnik</sys:String>
    <sys:String x:Key="Wizard_AutoDetectHint" xmlns:sys="clr-namespace:System;assembly=mscorlib">AI automatycznie znajdzie obszary dialogu</sys:String>
    <sys:String x:Key="Wizard_AutoDetectButton" xmlns:sys="clr-namespace:System;assembly=mscorlib">Wykryj obszary automatycznie</sys:String>
    <sys:String x:Key="Wizard_OrManually" xmlns:sys="clr-namespace:System;assembly=mscorlib">  lub wybierz ręcznie  </sys:String>
    <sys:String x:Key="Wizard_SchematicSelectLabel" xmlns:sys="clr-namespace:System;assembly=mscorlib">Wybierz ten obszar</sys:String>
    <sys:String x:Key="Wizard_SchematicSizeHint" xmlns:sys="clr-namespace:System;assembly=mscorlib">Dopasuj wielkość do NPC z trzema liniami — dodaj trochę zapasu, by dłuższe się zmieściły</sys:String>
    <sys:String x:Key="Wizard_SchematicDialogueLine" xmlns:sys="clr-namespace:System;assembly=mscorlib">Podróżniku, ruszajmy na przygodę!</sys:String>
    <sys:String x:Key="Wizard_BtnSelectDialogue" xmlns:sys="clr-namespace:System;assembly=mscorlib">Wybierz obszar dialogu</sys:String>
    <sys:String x:Key="Wizard_Step1_StatusNone" xmlns:sys="clr-namespace:System;assembly=mscorlib">Nie wybrano jeszcze obszaru</sys:String>

    <sys:String x:Key="Wizard_Step2_DisabledHeading" xmlns:sys="clr-namespace:System;assembly=mscorlib">Tłumaczenie odpowiedzi — chwilowo niedostępne</sys:String>
    <sys:String x:Key="Wizard_Step2_DisabledBody" xmlns:sys="clr-namespace:System;assembly=mscorlib">Wyłączyliśmy tę funkcję na czas stabilizacji głównego tłumaczenia. Wróci w kolejnej aktualizacji — z Twojej strony nic nie trzeba robić. Kliknij Dalej, aby kontynuować.</sys:String>
    <sys:String x:Key="Wizard_Step2_DisabledFootnote" xmlns:sys="clr-namespace:System;assembly=mscorlib">Jeśli już wybrałeś obszar odpowiedzi w poprzedniej sesji, pozostanie zapisany i zostanie użyty automatycznie, gdy funkcja wróci.</sys:String>
    <sys:String x:Key="Wizard_Step2_Title" xmlns:sys="clr-namespace:System;assembly=mscorlib">Wybierz obszar odpowiedzi</sys:String>
    <sys:String x:Key="Wizard_Step2_Subtitle" xmlns:sys="clr-namespace:System;assembly=mscorlib">Wskaż miejsce, w którym pojawiają się opcje dialogowe</sys:String>
    <sys:String x:Key="Wizard_OptionalBadge" xmlns:sys="clr-namespace:System;assembly=mscorlib">OPCJONALNE</sys:String>
    <sys:String x:Key="Wizard_SchematicDialogueRegion" xmlns:sys="clr-namespace:System;assembly=mscorlib">Obszar dialogu</sys:String>
    <sys:String x:Key="Wizard_SchematicAnswer1" xmlns:sys="clr-namespace:System;assembly=mscorlib">Opowiedz mi o tym więcej</sys:String>
    <sys:String x:Key="Wizard_SchematicAnswer2" xmlns:sys="clr-namespace:System;assembly=mscorlib">Pewnie, ruszamy!</sys:String>
    <sys:String x:Key="Wizard_SchematicAnswer3" xmlns:sys="clr-namespace:System;assembly=mscorlib">Może innym razem...</sys:String>
