    <sys:String x:Key="Wizard_SignOut_Confirm_Body" xmlns:sys="clr-namespace:System;assembly=mscorlib">Wylogować z Kaption? Aby ponownie korzystać z aplikacji, musisz znów się zalogować.</sys:String>
    <sys:String x:Key="Wizard_SignOut_Confirm_Title" xmlns:sys="clr-namespace:System;assembly=mscorlib">Wylogowanie</sys:String>
    <sys:String x:Key="Wizard_SignOut_FailedBody" xmlns:sys="clr-namespace:System;assembly=mscorlib">Nie udało się poprawnie wylogować. Uruchom Kaption ponownie, aby dokończyć wylogowanie.</sys:String>

    <sys:String x:Key="Wizard_Section_Overlay" xmlns:sys="clr-namespace:System;assembly=mscorlib">Nakładka</sys:String>
    <sys:String x:Key="Wizard_Section_Translation" xmlns:sys="clr-namespace:System;assembly=mscorlib">Tłumaczenie</sys:String>
    <sys:String x:Key="Wizard_Section_Regions" xmlns:sys="clr-namespace:System;assembly=mscorlib">Obszar dialogu</sys:String>
    <sys:String x:Key="Wizard_Tip_DragTitle" xmlns:sys="clr-namespace:System;assembly=mscorlib">Przeciągnij, by zmienić położenie</sys:String>
    <sys:String x:Key="Wizard_Tip_DragBody" xmlns:sys="clr-namespace:System;assembly=mscorlib"> — Kliknij i przeciągnij okno napisów, aby je przesunąć. Położenie zapisuje się automatycznie.</sys:String>
    <sys:String x:Key="Wizard_Tip_ClickThroughTitle" xmlns:sys="clr-namespace:System;assembly=mscorlib">Przesuwanie napisów</sys:String>
    <sys:String x:Key="Wizard_Tip_ClickThroughBody" xmlns:sys="clr-namespace:System;assembly=mscorlib"> — Po prostu złap okienko z napisami i przeciągnij je gdzie chcesz. Ctrl+Shift+D pokazuje ramkę dialogu, żebyś wiedział, gdzie Kaption patrzy.</sys:String>
    <sys:String x:Key="Wizard_Tip_FontTitle" xmlns:sys="clr-namespace:System;assembly=mscorlib">Czcionka i rozmiar</sys:String>
    <sys:String x:Key="Wizard_Tip_FontBody" xmlns:sys="clr-namespace:System;assembly=mscorlib"> — Dostosuj w zakładce Wygląd. Możesz też ustawić maksymalną szerokość i wysokość okna napisów.</sys:String>
    <sys:String x:Key="Wizard_Tip_AnswerTrTitle" xmlns:sys="clr-namespace:System;assembly=mscorlib">Tłumaczenie odpowiedzi</sys:String>
    <sys:String x:Key="Wizard_Tip_AnswerTrBody" xmlns:sys="clr-namespace:System;assembly=mscorlib"> — Włącz w Ustawieniach &gt; Opcje, aby tłumaczyć opcje dialogowe gracza. Wymaga ustawienia obszaru odpowiedzi w zakładce Obszary.</sys:String>
    <sys:String x:Key="Wizard_Tip_PlayerNameTitle" xmlns:sys="clr-namespace:System;assembly=mscorlib">Imię postaci</sys:String>
    <sys:String x:Key="Wizard_Tip_PlayerNameBody" xmlns:sys="clr-namespace:System;assembly=mscorlib"> — Wpisz imię postaci w Ustawieniach &gt; Opcje, żeby pojawiało się w dialogach. Jeśli tego nie zrobisz, Kaption użyje domyślnego „Traveler".</sys:String>
    <sys:String x:Key="Wizard_Tip_PredictionTitle" xmlns:sys="clr-namespace:System;assembly=mscorlib">Przewidywanie dialogów</sys:String>
    <sys:String x:Key="Wizard_Tip_PredictionBody" xmlns:sys="clr-namespace:System;assembly=mscorlib"> — Aplikacja przewiduje kolejną linię dialogu na podstawie danych gry i pokazuje tłumaczenia, zanim w ogóle zdąży je przeskanować.</sys:String>
    <sys:String x:Key="Wizard_Tip_ShowRegionsTitle" xmlns:sys="clr-namespace:System;assembly=mscorlib">Pokaż obszary</sys:String>
    <sys:String x:Key="Wizard_Tip_ShowRegionsBody" xmlns:sys="clr-namespace:System;assembly=mscorlib"> — Użyj przycisku „Pokaż obszar" w zakładce Obszary, aby upewnić się, że pola przechwytywania są w dobrym miejscu.</sys:String>
    <sys:String x:Key="Wizard_Tip_OcrTuningTitle" xmlns:sys="clr-namespace:System;assembly=mscorlib">Dostrajanie wydajności</sys:String>
    <sys:String x:Key="Wizard_Tip_OcrTuningBody" xmlns:sys="clr-namespace:System;assembly=mscorlib"> — Zmieniaj szybkość skanowania i okno stabilności w zakładce Ustawienia. Mniejsze wartości = szybciej, ale większe zużycie CPU. Większe = bardziej stabilny wynik.</sys:String>
    <sys:String x:Key="Wizard_Tip_ManualTitle" xmlns:sys="clr-namespace:System;assembly=mscorlib">Obszar ręczny</sys:String>
    <sys:String x:Key="Wizard_Tip_ManualBody" xmlns:sys="clr-namespace:System;assembly=mscorlib"> — Jeśli automatyczne wykrywanie nie działa najlepiej, użyj „Wybierz obszar", by ręcznie narysować pole przechwytywania. Dopracuj wartości w polach X/Y/W/H.</sys:String>

