    <!-- Main window dialogs -->
    <sys:String x:Key="Dialog_OcrEngineFailed_Title" xmlns:sys="clr-namespace:System;assembly=mscorlib">Nie udało się wczytać tłumacza</sys:String>
    <sys:String x:Key="Dialog_OcrEngineFailed_Body" xmlns:sys="clr-namespace:System;assembly=mscorlib">Tłumaczenie napisów nie zadziała, dopóki tego nie rozwiążemy. Spróbuj uruchomić Kaption ponownie; jeśli błąd się powtarza, zwykle pomaga reinstalacja.</sys:String>
    <sys:String x:Key="Dialog_StillStarting_Title" xmlns:sys="clr-namespace:System;assembly=mscorlib">Uruchamianie w toku</sys:String>
    <sys:String x:Key="Dialog_StillStarting_Body" xmlns:sys="clr-namespace:System;assembly=mscorlib">Kaption jeszcze się przygotowuje. Spróbuj ponownie za chwilę.</sys:String>
    <sys:String x:Key="Dialog_SignInOpenFailed_Title" xmlns:sys="clr-namespace:System;assembly=mscorlib">Nie udało się otworzyć logowania</sys:String>
    <sys:String x:Key="Dialog_SignInOpenFailed_Body" xmlns:sys="clr-namespace:System;assembly=mscorlib">Kaption nie otworzył okna logowania. Zamknij aplikację i uruchom ją ponownie.</sys:String>
    <sys:String x:Key="Dialog_RegionMissing_Title" xmlns:sys="clr-namespace:System;assembly=mscorlib">Brak obszaru przechwytywania</sys:String>
    <sys:String x:Key="Dialog_RegionMissing_Body" xmlns:sys="clr-namespace:System;assembly=mscorlib">Zanim uruchomisz tłumaczenie, wskaż fragment ekranu, w którym pojawiają się dialogi w grze.</sys:String>
    <sys:String x:Key="Dialog_RegionMissing_Details" xmlns:sys="clr-namespace:System;assembly=mscorlib">Wróć do kroku Obszar w kreatorze albo otwórz Ustawienia › Obszary i kliknij „Wybierz obszar", po czym spróbuj ponownie.</sys:String>
    <sys:String x:Key="Dialog_PackMissing_Title" xmlns:sys="clr-namespace:System;assembly=mscorlib">Brak paczki tłumaczeń</sys:String>
    <sys:String x:Key="Dialog_PackMissing_Details" xmlns:sys="clr-namespace:System;assembly=mscorlib">Napisy będą wyświetlane w oryginalnym języku angielskim, dopóki paczka nie będzie dostępna. Język docelowy zmienisz w Ustawieniach › Pulpicie.</sys:String>
    <sys:String x:Key="Dialog_GameDataUpdated_Title" xmlns:sys="clr-namespace:System;assembly=mscorlib">Dane gry zaktualizowane</sys:String>
    <sys:String x:Key="Dialog_GameDataUpdated_Body" xmlns:sys="clr-namespace:System;assembly=mscorlib">Kaption pobrał nowszą wersję publicznych danych gry. Uruchom Kaption ponownie, aby zbudować indeks tłumaczeń z nowymi tekstami.</sys:String>
    <sys:String x:Key="Dialog_UpdateDownloadFailed_Body" xmlns:sys="clr-namespace:System;assembly=mscorlib">Nie udało się pobrać aktualizacji. Sprawdź połączenie z internetem i spróbuj później.</sys:String>
    <sys:String x:Key="Dialog_UpdateRestartFailed_Body" xmlns:sys="clr-namespace:System;assembly=mscorlib">Aktualizacja pobrała się poprawnie, ale nie udało się zakolejkować ponownego uruchomienia. Spróbuj później.</sys:String>
    <sys:String x:Key="Dialog_UpdateInstallFailed_Body" xmlns:sys="clr-namespace:System;assembly=mscorlib">Nie udało się dokończyć aktualizacji Kaption. Spróbuj później; jeśli problem się powtarza, zainstaluj ponownie.</sys:String>
    <sys:String x:Key="Update_WhatsNew_Title_Format" xmlns:sys="clr-namespace:System;assembly=mscorlib">Kaption {0} — Co nowego</sys:String>
    <sys:String x:Key="Update_Downloading_Title_Format" xmlns:sys="clr-namespace:System;assembly=mscorlib">Kaption — Pobieranie {0}</sys:String>
    <sys:String x:Key="Update_Applying" xmlns:sys="clr-namespace:System;assembly=mscorlib">Stosowanie…</sys:String>
    <sys:String x:Key="Update_Balloon_Title" xmlns:sys="clr-namespace:System;assembly=mscorlib">Dostępna aktualizacja Kaption</sys:String>
    <sys:String x:Key="Update_Balloon_Body_Format" xmlns:sys="clr-namespace:System;assembly=mscorlib">Wersja {0} jest gotowa do instalacji. Kliknij, żeby otworzyć Ustawienia.</sys:String>

