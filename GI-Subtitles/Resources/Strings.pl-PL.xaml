    <sys:String x:Key="Wizard_Step4_Title" xmlns:sys="clr-namespace:System;assembly=mscorlib">Porady i ustawienia</sys:String>
    <sys:String x:Key="Wizard_Step4_Subtitle" xmlns:sys="clr-namespace:System;assembly=mscorlib">Przydatne funkcje, które możesz dostosować</sys:String>
    <sys:String x:Key="Wizard_Referral_Heading" xmlns:sys="clr-namespace:System;assembly=mscorlib">ZAPROSIŁ CIĘ ZNAJOMY?</sys:String>
    <sys:String x:Key="Wizard_Referral_Body" xmlns:sys="clr-namespace:System;assembly=mscorlib">Wklej jego kod, żeby oboje dostać bonus. Działa tylko przez pierwsze 7 dni od założenia konta.</sys:String>
    <sys:String x:Key="Wizard_Referral_Skip" xmlns:sys="clr-namespace:System;assembly=mscorlib">Pomiń</sys:String>
    <sys:String x:Key="Wizard_Referral_Submit" xmlns:sys="clr-namespace:System;assembly=mscorlib">Zatwierdź</sys:String>
    <sys:String x:Key="Wizard_Referral_Submitting" xmlns:sys="clr-namespace:System;assembly=mscorlib">Wysyłanie…</sys:String>
    <sys:String x:Key="Wizard_Referral_Invalid" xmlns:sys="clr-namespace:System;assembly=mscorlib">To nie wygląda na prawidłowy kod. Poproś znajomego, żeby wysłał go jeszcze raz.</sys:String>
    <sys:String x:Key="Wizard_Referral_SignInFirst" xmlns:sys="clr-namespace:System;assembly=mscorlib">Najpierw się zaloguj.</sys:String>
    <sys:String x:Key="Wizard_Referral_Thanks" xmlns:sys="clr-namespace:System;assembly=mscorlib">Dzięki! Twój znajomy dostanie bonus, gdy zaczniesz korzystać z Kaption.</sys:String>
    <sys:String x:Key="Wizard_Referral_Expired" xmlns:sys="clr-namespace:System;assembly=mscorlib">Twoja sesja wygasła. Zaloguj się ponownie.</sys:String>
    <sys:String x:Key="Wizard_Referral_SelfReferral" xmlns:sys="clr-namespace:System;assembly=mscorlib">Nie można przypisać tego kodu do Twojego konta (polecenie samego siebie?).</sys:String>
    <sys:String x:Key="Wizard_Referral_Conflict" xmlns:sys="clr-namespace:System;assembly=mscorlib">Wygląda na to, że jesteś już powiązany z polecającym albo ten kod został już użyty.</sys:String>
    <sys:String x:Key="Wizard_Referral_PastWindow" xmlns:sys="clr-namespace:System;assembly=mscorlib">Kod jest nieprawidłowy albo Twoje konto ma już ponad 7 dni.</sys:String>
    <sys:String x:Key="Wizard_Referral_Unreachable" xmlns:sys="clr-namespace:System;assembly=mscorlib">Nie udało się połączyć z serwerami Kaption. Sprawdź połączenie i spróbuj ponownie.</sys:String>
    <sys:String x:Key="Wizard_Referral_Timeout" xmlns:sys="clr-namespace:System;assembly=mscorlib">Żądanie trwało zbyt długo. Spróbuj ponownie.</sys:String>
    <sys:String x:Key="Wizard_Referral_Generic" xmlns:sys="clr-namespace:System;assembly=mscorlib">Coś poszło nie tak. Spróbuj ponownie.</sys:String>

