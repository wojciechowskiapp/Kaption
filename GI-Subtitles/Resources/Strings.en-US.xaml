    <sys:String x:Key="FullscreenTip_Step2" xmlns:sys="clr-namespace:System;assembly=mscorlib">Set Display Mode to Borderless (or Windowed)</sys:String>
    <sys:String x:Key="FullscreenTip_Step3" xmlns:sys="clr-namespace:System;assembly=mscorlib">For a fullscreen-like view, press Alt+Enter inside the game</sys:String>
