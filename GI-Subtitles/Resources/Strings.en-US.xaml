    <sys:String x:Key="Wizard_Tip_PredictionBody" xmlns:sys="clr-namespace:System;assembly=mscorlib"> — The app predicts the next dialogue line from game data and shows translations ahead of the scan.</sys:String>
    <sys:String x:Key="Wizard_Tip_ShowRegionsTitle" xmlns:sys="clr-namespace:System;assembly=mscorlib">Show regions</sys:String>
    <sys:String x:Key="Wizard_Tip_ShowRegionsBody" xmlns:sys="clr-namespace:System;assembly=mscorlib"> — Use the "Show Region" button in the Regions tab to verify your capture areas are positioned correctly.</sys:String>
    <sys:String x:Key="Wizard_Tip_OcrTuningTitle" xmlns:sys="clr-namespace:System;assembly=mscorlib">Performance tuning</sys:String>
    <sys:String x:Key="Wizard_Tip_OcrTuningBody" xmlns:sys="clr-namespace:System;assembly=mscorlib"> — Adjust scan speed and stability window in the Settings tab. Lower values = faster but uses more CPU. Higher = more stable results.</sys:String>
    <sys:String x:Key="Wizard_Tip_ManualTitle" xmlns:sys="clr-namespace:System;assembly=mscorlib">Manual region</sys:String>
    <sys:String x:Key="Wizard_Tip_ManualBody" xmlns:sys="clr-namespace:System;assembly=mscorlib"> — If auto-detect doesn't work well, use "Select Region" to draw the capture area manually. Fine-tune with the X/Y/W/H fields.</sys:String>

