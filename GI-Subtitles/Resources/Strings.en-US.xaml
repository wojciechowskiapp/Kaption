    <sys:String x:Key="Wizard_Tip_AnswerTrBody" xmlns:sys="clr-namespace:System;assembly=mscorlib"> — Enable in Settings &gt; Options to translate player dialogue choices. Requires an answer region set up in the Regions tab.</sys:String>
    <sys:String x:Key="Wizard_Tip_PlayerNameTitle" xmlns:sys="clr-namespace:System;assembly=mscorlib">Player name</sys:String>
    <sys:String x:Key="Wizard_Tip_PlayerNameBody" xmlns:sys="clr-namespace:System;assembly=mscorlib"> — Set your character name in Settings &gt; Options so every dialogue line uses it. If you skip this, Kaption falls back to "Traveler" everywhere.</sys:String>
