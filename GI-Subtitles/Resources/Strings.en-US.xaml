    <!-- "Subtitles cover the dialogue" / feedback-loop prevention strings.
         ONE copy shared across all surfaces: the OCR-start gate confirm,
         the post-change warn dialog, and the runtime red-alert banner.
         Shorter variants for diagnostic overlays + inline hints below. -->
    <sys:String x:Key="Dialog_OverlayInRegion_Title" xmlns:sys="clr-namespace:System;assembly=mscorlib">⚠ Subtitles cover the game's dialogue</sys:String>
    <sys:String x:Key="Dialog_OverlayInRegion_Body" xmlns:sys="clr-namespace:System;assembly=mscorlib">The subtitle box is sitting on top of the game's dialogue — Kaption would start reading its own translation and loop forever. Drag the subtitle box out of the way, change its position in Settings → Appearance → Manual offset → Vertical, or press Ctrl+Shift+R to redraw the dialogue area. Translation resumes as soon as the box is clear.</sys:String>
    <sys:String x:Key="Dialog_OverlayInRegion_Details" xmlns:sys="clr-namespace:System;assembly=mscorlib">Still overlapping after moving things around? In Settings → Display, lower Max subtitle height or raise vertical padding so the subtitle box sits further above the dialogue. Guide with diagrams: kaption.one/how-to/region#overlap</sys:String>
    <sys:String x:Key="Dialog_OverlayInRegion_Primary" xmlns:sys="clr-namespace:System;assembly=mscorlib">Continue anyway</sys:String>
    <sys:String x:Key="Dialog_OverlayInRegion_Secondary" xmlns:sys="clr-namespace:System;assembly=mscorlib">Reselect region</sys:String>
    <!-- Short label for Ctrl+Shift+D region outline when the subtitle box is inside it. -->
    <sys:String x:Key="Overlap_Badge_Warning" xmlns:sys="clr-namespace:System;assembly=mscorlib">⚠ Subtitles cover the dialogue — translation won't work here</sys:String>
    <!-- Text shown INSIDE the subtitle box itself in the two "please grab me" states. -->
