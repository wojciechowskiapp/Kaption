<Window x:Class="GI_Subtitles.Views.ReferralsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Referrals_WindowTitle}"
        Height="640" Width="560"
        Icon="../Resources/kaption.ico"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        MinWidth="520" MinHeight="500"
        ShowInTaskbar="False"
        Background="#F8F9FC"
        ToolTipService.InitialShowDelay="0"
        ToolTipService.BetweenShowDelay="0"
        ToolTipService.ShowDuration="20000">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/ModernStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Stat-card template — 4 used in the stats row. -->
            <Style TargetType="Border" x:Key="StatCard">
                <Setter Property="Background" Value="White"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="12,10"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             LOADING PLACEHOLDER — swapped in/out from code-behind so the
             user doesn't stare at zero-filled cards while /ensure-code
             round-trips.
             ═══════════════════════════════════════════════════════════════ -->
        <Grid x:Name="LoadingPanel" Grid.Row="0" Background="#F8F9FC">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="{DynamicResource Referrals_Loading}"
                           FontSize="14" FontWeight="Medium"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
                <ProgressBar IsIndeterminate="True"
                             Width="180" Height="3" Margin="0,12,0,0"
                             Background="#E5E7EB" Foreground="{StaticResource AccentBrush}"
                             BorderThickness="0"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             ERROR STATE — shown when /ensure-code fails. Retry button
             restarts the load cycle. Unauthorized / tier errors bubble
             up as human-readable text.
             ═══════════════════════════════════════════════════════════════ -->
        <Grid x:Name="ErrorPanel" Grid.Row="0" Background="#F8F9FC" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="380">
                <TextBlock Text="{DynamicResource Referrals_LoadError_Title}"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock x:Name="ErrorMessageText"
                           FontSize="12" TextWrapping="Wrap"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextAlignment="Center" Margin="0,0,0,16"/>
                <Button x:Name="BtnRetryLoad"
                        Style="{StaticResource ModernButton}"
                        Content="{DynamicResource Referrals_TryAgain}"
                        MinWidth="120"
                        HorizontalAlignment="Center"
                        Click="RetryLoad_Click"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT — the interesting part. Scrolls vertically; every
             card stretches to the window width so resizing looks natural.
             ═══════════════════════════════════════════════════════════════ -->
        <ScrollViewer x:Name="ContentScroll" Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="Collapsed"
                      Padding="20,16,20,14">
            <StackPanel>

                <!-- Page title row — kept tight; the full marketing copy
                     lives on the web page. Desktop is for "grab code, see
                     progress, claim". -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{DynamicResource Referrals_Heading}"
                                   FontSize="17" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="{DynamicResource Referrals_Subheading}"
                                   FontSize="11" TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- ═════════════════════════════════════════════════════
                     CODE + SHARE URL CARD
                     ═════════════════════════════════════════════════════ -->
                <Border Background="White" CornerRadius="10"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        Padding="16,14" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Referrals_CodeLabel}"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   Margin="0,0,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="CodeText" Grid.Column="0"
                                       Text="----"
                                       FontSize="22" FontWeight="Bold"
                                       FontFamily="Consolas"
                                       Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="BtnCopyCode" Grid.Column="1"
                                    Style="{StaticResource SecondaryButton}"
                                    Content="{DynamicResource Referrals_CopyCode}"
                                    MinWidth="100"
                                    VerticalAlignment="Center"
                                    Click="CopyCode_Click"
                                    AutomationProperties.Name="{DynamicResource Referrals_CopyCode_Automation}"/>
                        </Grid>

                        <TextBlock Text="{DynamicResource Referrals_ShareLinkLabel}"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   Margin="0,14,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Background="#F3F4F6"
                                    CornerRadius="6"
                                    Padding="10,6"
                                    VerticalAlignment="Center">
                                <TextBox x:Name="ShareUrlText"
                                         IsReadOnly="True"
                                         BorderThickness="0" Background="Transparent"
                                         FontSize="12"
                                         Foreground="{StaticResource TextBrush}"
                                         TextWrapping="NoWrap"
                                         Text=""/>
                            </Border>
                            <!-- Primary share CTA: one button, one job. "Open web"
                                 moved to the footer so the hero stays focused. -->
                            <Button x:Name="BtnCopyUrl" Grid.Column="1"
                                    Style="{StaticResource ModernButton}"
                                    Content="{DynamicResource Referrals_Share_Primary}"
                                    MinWidth="140"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Click="CopyUrl_Click"
                                    AutomationProperties.Name="{DynamicResource Referrals_CopyLink_Automation}"/>
                            <!-- Kept in the tree (Visibility=Collapsed) so the
                                 CodeBehind's x:Name reference still resolves. -->
                            <Button x:Name="BtnOpenReferrals"
                                    Visibility="Collapsed"
                                    Click="OpenReferrals_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ═════════════════════════════════════════════════════
                     STATS ROW
                     ═════════════════════════════════════════════════════ -->
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource StatCard}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Referrals_Stat_Invited}"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                            <TextBlock x:Name="StatInvitedText" Text="0"
                                       FontSize="19" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource StatCard}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Referrals_Stat_Active}"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                            <TextBlock x:Name="StatActiveText" Text="0"
                                       FontSize="19" FontWeight="SemiBold"
                                       Foreground="{StaticResource SuccessBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Style="{StaticResource StatCard}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Referrals_Stat_BonusDays}"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                            <TextBlock x:Name="StatBonusDaysText" Text="0"
                                       FontSize="19" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="6" Style="{StaticResource StatCard}"
                            ToolTip="{DynamicResource Referrals_Stat_Pending_Tooltip}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Referrals_Stat_Pending}"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                            <TextBlock x:Name="StatPendingText" Text="0"
                                       FontSize="19" FontWeight="SemiBold"
                                       Foreground="#B45309"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ═════════════════════════════════════════════════════
                     PROGRESS BARS — 15 active + 40 active reward tiers.
                     Threshold values mirror landing/src/data/referral-tiers.mjs
                     and ReferralsWindow.xaml.cs::TierLowerFriends/TierUpperFriends.
                     ═════════════════════════════════════════════════════ -->
                <Border Background="White" CornerRadius="10"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        Padding="16,12" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Referrals_TiersLabel}"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   Margin="0,0,0,10"/>

                        <!-- Tier 1: 15 active = 1980 crystals (~$30) -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       FontSize="12" FontWeight="Medium"
                                       Foreground="{StaticResource TextBrush}">
                                <Run Text="{DynamicResource Referrals_Tier1_AmountPrefix}"/>
                                <Run FontWeight="Normal"
                                     Foreground="{StaticResource TextSecondaryBrush}"
                                     Text="{DynamicResource Referrals_Tier1_Suffix}"/>
                            </TextBlock>
                            <TextBlock x:Name="Tier1ProgressText" Grid.Column="1"
                                       Text="0 / 15"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Grid>
                        <ProgressBar x:Name="Tier1Progress"
                                     Minimum="0" Maximum="15" Value="0"
                                     Height="6"
                                     Background="#E5E7EB" Foreground="{StaticResource AccentBrush}"
                                     BorderThickness="0"/>

                        <!-- Tier 2: 40 active = 3280 crystals -->
                        <Grid Margin="0,14,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       FontSize="12" FontWeight="Medium"
                                       Foreground="{StaticResource TextBrush}">
                                <Run Text="{DynamicResource Referrals_Tier2_AmountPrefix}"/>
                                <Run FontWeight="Normal"
                                     Foreground="{StaticResource TextSecondaryBrush}"
                                     Text="{DynamicResource Referrals_Tier2_Suffix}"/>
                            </TextBlock>
                            <TextBlock x:Name="Tier2ProgressText" Grid.Column="1"
                                       Text="0 / 40"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Grid>
                        <ProgressBar x:Name="Tier2Progress"
                                     Minimum="0" Maximum="40" Value="0"
                                     Height="6"
                                     Background="#E5E7EB" Foreground="{StaticResource SuccessBrush}"
                                     BorderThickness="0"/>
                    </StackPanel>
                </Border>

                <!-- ═════════════════════════════════════════════════════
                     INVITED FRIENDS — one row per signup attributed to the
                     user's code, pending first so the most actionable state
                     leads. Hidden when the list is empty so a new user
                     doesn't see a sad placeholder card.
                     ═════════════════════════════════════════════════════ -->
                <Border x:Name="InviteesCard"
                        Background="White" CornerRadius="10"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        Padding="16,12" Margin="0,12,0,0"
                        Visibility="Collapsed">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{DynamicResource Referrals_InviteesLabel}"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="InviteesSubtitleText" Grid.Column="1"
                                       FontSize="10"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="{DynamicResource Referrals_InviteesNote}"
                                   FontSize="11" TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,8"/>
                        <ItemsControl x:Name="InviteesList"/>
                    </StackPanel>
                </Border>

                <!-- ═════════════════════════════════════════════════════
                     REWARDS LIST — one row per ReferralReward, visible only
                     when at least one exists.
                     ═════════════════════════════════════════════════════ -->
                <Border x:Name="RewardsCard"
                        Background="White" CornerRadius="10"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        Padding="16,12" Margin="0,12,0,0"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Referrals_RewardsLabel}"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   Margin="0,0,0,10"/>
                        <ItemsControl x:Name="RewardsList"/>
                    </StackPanel>
                </Border>

                <!-- ═════════════════════════════════════════════════════
                     INLINE CLAIM PANEL — expanded when user clicks "Claim"
                     on a reward row. Stays in the same XAML rather than a
                     separate window so the user keeps context and the
                     entire flow is one dialog.
                     ═════════════════════════════════════════════════════ -->
                <Border x:Name="ClaimPanel"
                        Background="#EEF2FF" CornerRadius="10"
                        BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                        Padding="18,14" Margin="0,12,0,0"
                        Visibility="Collapsed">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{DynamicResource Referrals_Claim_Heading}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"/>
                            <Button Grid.Column="1"
                                    Content="{DynamicResource Common_Cancel}"
                                    Style="{StaticResource SecondaryButton}"
                                    MinWidth="70"
                                    Click="ClaimCancel_Click"/>
                        </Grid>
                        <TextBlock x:Name="ClaimRewardSummary"
                                   FontSize="12" Margin="0,4,0,10"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"/>

                        <!-- Delivery method radios -->
                        <TextBlock Text="{DynamicResource Referrals_Claim_DeliveryPrompt}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,0,6"/>
                        <StackPanel>
                            <RadioButton x:Name="RadioHoyolab"
                                         Content="{DynamicResource Referrals_Claim_Method_Hoyolab}"
                                         GroupName="DeliveryMethod"
                                         IsChecked="True"
                                         Checked="DeliveryMethod_Changed"
                                         FontSize="12"
                                         Foreground="{StaticResource TextBrush}"
                                         Margin="0,0,0,4"/>
                            <RadioButton x:Name="RadioPaypal"
                                         Content="{DynamicResource Referrals_Claim_Method_PayPal}"
                                         GroupName="DeliveryMethod"
                                         Checked="DeliveryMethod_Changed"
                                         FontSize="12"
                                         Foreground="{StaticResource TextBrush}"
                                         Margin="0,0,0,4"/>
                            <RadioButton x:Name="RadioAmazon"
                                         Content="{DynamicResource Referrals_Claim_Method_Amazon}"
                                         GroupName="DeliveryMethod"
                                         Checked="DeliveryMethod_Changed"
                                         FontSize="12"
                                         Foreground="{StaticResource TextBrush}"/>
                        </StackPanel>

                        <!-- HoYoLAB-specific inputs: UID + region dropdown -->
                        <Grid x:Name="HoyolabInputPanel" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="{DynamicResource Referrals_Claim_Uid_Label}"
                                       FontSize="11" FontWeight="Medium"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,3"/>
                            <TextBlock Grid.Row="0" Grid.Column="2"
                                       Text="{DynamicResource Referrals_Claim_Region_Label}"
                                       FontSize="11" FontWeight="Medium"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,3"/>
                            <Border Grid.Row="1" Grid.Column="0"
                                    Background="White" CornerRadius="6"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Padding="8,6">
                                <TextBox x:Name="HoyolabUidBox"
                                         MaxLength="12"
                                         BorderThickness="0" Background="Transparent"
                                         FontSize="13"
                                         ToolTip="{DynamicResource Referrals_Claim_Uid_Tooltip}"
                                         TextChanged="ClaimField_TextChanged"/>
                            </Border>
                            <ComboBox x:Name="HoyolabRegionCombo" Grid.Row="1" Grid.Column="2"
                                      Height="32"
                                      SelectionChanged="HoyolabRegion_SelectionChanged">
                                <ComboBoxItem Content="{DynamicResource Referrals_Claim_Region_Americas}" Tag="NA" IsSelected="True"/>
                                <ComboBoxItem Content="{DynamicResource Referrals_Claim_Region_Europe}" Tag="EU"/>
                                <ComboBoxItem Content="{DynamicResource Referrals_Claim_Region_Asia}" Tag="ASIA"/>
                                <ComboBoxItem Content="{DynamicResource Referrals_Claim_Region_TW}" Tag="TW"/>
                            </ComboBox>
                        </Grid>

                        <!-- Email input (used for PayPal / Amazon Gift Card) -->
                        <Grid x:Name="EmailInputPanel" Margin="0,12,0,0" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       x:Name="EmailLabel"
                                       Text="{DynamicResource Referrals_Claim_Email_Label}"
                                       FontSize="11" FontWeight="Medium"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,3"/>
                            <Border Grid.Row="1"
                                    Background="White" CornerRadius="6"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Padding="8,6">
                                <TextBox x:Name="EmailBox"
                                         MaxLength="200"
                                         BorderThickness="0" Background="Transparent"
                                         FontSize="13"
                                         TextChanged="ClaimField_TextChanged"/>
                            </Border>
                        </Grid>

                        <!-- Error / submit row -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="ClaimErrorText" Grid.Column="0"
                                       FontSize="11"
                                       Foreground="#B91C1C"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                            <Button x:Name="BtnSubmitClaim" Grid.Column="1"
                                    Style="{StaticResource ModernButton}"
                                    Content="{DynamicResource Referrals_Claim_Submit}"
                                    MinWidth="120"
                                    Click="SubmitClaim_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ═════════════════════════════════════════════════════
                     "INVITED BY A FRIEND?" PANEL
                     Always rendered. The server rejects codes from users who
                     are past the 7-day window or already attributed; we just
                     surface those errors inline. First-launch setup wizard
                     also surfaces this question, so most users will have
                     already answered it there.
                     ═════════════════════════════════════════════════════ -->
                <Border Background="White" CornerRadius="10"
                        BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                        Padding="18,14" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Referrals_Attribute_Label}"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="{DynamicResource Referrals_Attribute_Explainer}"
                                   FontSize="12" TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Background="#F3F4F6" CornerRadius="6"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Padding="10,6"
                                    VerticalAlignment="Center">
                                <TextBox x:Name="AttributeCodeBox"
                                         MaxLength="32"
                                         BorderThickness="0" Background="Transparent"
                                         FontSize="14" FontFamily="Consolas"
                                         CharacterCasing="Upper"
                                         TextChanged="AttributeCode_TextChanged"/>
                            </Border>
                            <Button x:Name="BtnAttributeSubmit" Grid.Column="1"
                                    Style="{StaticResource ModernButton}"
                                    Content="{DynamicResource Referrals_Attribute_Submit}"
                                    MinWidth="96"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    IsEnabled="False"
                                    Click="AttributeSubmit_Click"/>
                        </Grid>
                        <TextBlock x:Name="AttributeStatusText"
                                   FontSize="11" TextWrapping="Wrap"
                                   Margin="0,8,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- Fraud / terms notice -->
                <TextBlock Margin="4,14,4,0"
                           FontSize="10" TextWrapping="Wrap"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           TextAlignment="Center">
                    <Run Text="{DynamicResource Referrals_Fraud_Prefix}"/>
                    <Hyperlink NavigateUri="https://kaption.one/referrals"
                               Foreground="{StaticResource AccentBrush}"
                               RequestNavigate="Hyperlink_RequestNavigate">kaption.one/referrals</Hyperlink>
                    <Run Text="{DynamicResource Referrals_Fraud_Suffix}"/>
                </TextBlock>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════════════════════
             FOOTER — Close button, always visible
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="White"
                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,0"
                Padding="24,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{DynamicResource Referrals_Footer_FullDetails}"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="{StaticResource TextTertiaryBrush}"/>
                <!-- Moved here from the hero row — keeps it discoverable but
                     out of the primary share flow. -->
                <Button Grid.Column="1"
                        x:Name="BtnFooterOpenWeb"
                        Style="{StaticResource SecondaryButton}"
                        Content="{DynamicResource Referrals_OpenWeb}"
                        MinWidth="120"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Click="OpenReferrals_Click"/>
                <Button Grid.Column="2"
                        x:Name="BtnClose"
                        Style="{StaticResource SecondaryButton}"
                        Content="{DynamicResource Common_Close}"
                        MinWidth="90"
                        Click="Close_Click"
                        IsCancel="True"/>
            </Grid>
        </Border>
    </Grid>
</Window>

