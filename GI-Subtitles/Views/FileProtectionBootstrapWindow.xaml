<Window x:Class="GI_Subtitles.Views.FileProtectionBootstrapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kaption"
        Height="220" Width="420"
        Icon="../Resources/kaption.ico"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Background="#F8F9FC"
        Closing="Window_Closing">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/ModernStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Storyboard x:Key="SpinnerStoryboard" RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                 Storyboard.TargetProperty="Angle"
                                 From="0" To="360" Duration="0:0:1.2"/>
            </Storyboard>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="32,28,32,24">
        <!-- ============================================================
             STATE 1: Working (default)
             ============================================================ -->
        <StackPanel x:Name="WorkingPanel" VerticalAlignment="Center">
            <Grid HorizontalAlignment="Center" Margin="0,0,0,16" Width="32" Height="32">
                <Ellipse Stroke="{StaticResource AccentBrush}" StrokeThickness="3"
                         Opacity="0.25"/>
                <Path x:Name="Spinner"
                      Stroke="{StaticResource AccentBrush}" StrokeThickness="3"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Data="M 16 1 A 15 15 0 0 1 31 16"
                      RenderTransformOrigin="0.5,0.5">
                    <Path.RenderTransform>
                        <RotateTransform x:Name="SpinnerRotate" Angle="0"/>
                    </Path.RenderTransform>
                </Path>
            </Grid>
            <TextBlock Text="Preparing translations…"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="WorkingDetail"
                       Text="One-time setup, takes a few seconds."
                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       TextWrapping="Wrap" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- ============================================================
             STATE 2: Error (shown after retries fail)
             ============================================================ -->
        <StackPanel x:Name="ErrorPanel" VerticalAlignment="Center" Visibility="Collapsed">
            <TextBlock Text="Couldn't reach Kaption servers"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock x:Name="ErrorDetail"
                       Text="Check your internet connection and try again."
                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       TextWrapping="Wrap" Margin="0,0,0,18"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="BtnRetry" Content="Retry"
                        Style="{StaticResource ModernButton}"
                        Width="100" Height="34" Margin="0,0,8,0"
                        Click="Retry_Click"/>
                <Button x:Name="BtnQuit" Content="Quit"
                        Style="{StaticResource SecondaryButton}"
                        Width="100" Height="34"
                        Click="Quit_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
