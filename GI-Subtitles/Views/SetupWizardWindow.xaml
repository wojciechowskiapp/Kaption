<Window x:Class="GI_Subtitles.Views.SetupWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Wizard_WindowTitle}"
        Height="680" Width="800"
        Icon="../Resources/kaption.ico"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Background="#F8F9FC">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/ModernStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Dashed stroke for selection rectangles -->
            <DoubleCollection x:Key="DashPattern">6,3</DoubleCollection>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ================================================================
             ROW 0: STEP INDICATOR
             ================================================================ -->
        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="0,0,0,1" Padding="0,20,0,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">

                <!-- Step 1 Circle -->
                <Grid Width="32" Height="32">
                    <Ellipse x:Name="Step1Circle" Width="32" Height="32"
                             Fill="{StaticResource AccentBrush}"/>
                    <TextBlock x:Name="Step1Number" Text="1"
                               FontSize="14" FontWeight="SemiBold" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

                <!-- Line 1 -->
                <Rectangle x:Name="Line1" Width="64" Height="3"
                           Fill="#E5E7EB" Margin="8,0" VerticalAlignment="Center"
                           RadiusX="1.5" RadiusY="1.5"/>

                <!-- Step 2 Circle -->
                <Grid Width="32" Height="32">
                    <Ellipse x:Name="Step2Circle" Width="32" Height="32"
                             Fill="#E5E7EB"/>
                    <TextBlock x:Name="Step2Number" Text="2"
                               FontSize="14" FontWeight="SemiBold" Foreground="#9CA3AF"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

                <!-- Line 2 -->
                <Rectangle x:Name="Line2" Width="64" Height="3"
                           Fill="#E5E7EB" Margin="8,0" VerticalAlignment="Center"
                           RadiusX="1.5" RadiusY="1.5"/>

                <!-- Step 3 Circle -->
                <Grid Width="32" Height="32">
                    <Ellipse x:Name="Step3Circle" Width="32" Height="32"
                             Fill="#E5E7EB"/>
                    <TextBlock x:Name="Step3Number" Text="3"
                               FontSize="14" FontWeight="SemiBold" Foreground="#9CA3AF"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

                <!-- Line 3 -->
                <Rectangle x:Name="Line3" Width="64" Height="3"
                           Fill="#E5E7EB" Margin="8,0" VerticalAlignment="Center"
                           RadiusX="1.5" RadiusY="1.5"/>

                <!-- Step 4 Circle -->
                <Grid Width="32" Height="32">
                    <Ellipse x:Name="Step4Circle" Width="32" Height="32"
                             Fill="#E5E7EB"/>
                    <TextBlock x:Name="Step4Number" Text="4"
                               FontSize="14" FontWeight="SemiBold" Foreground="#9CA3AF"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ================================================================
             ROW 1: CONTENT AREA
             ================================================================ -->
        <Grid Grid.Row="1" Margin="0">

            <!-- ============================================================
                 STEP 1: Select Dialogue Region
                 ============================================================ -->
            <Grid x:Name="Step1Panel" Visibility="Visible">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="40,24,40,8">

                        <!-- Title -->
                        <TextBlock Text="{DynamicResource Wizard_Step1_Title}"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   HorizontalAlignment="Center"/>

                        <!-- Subtitle -->
                        <TextBlock Text="{DynamicResource Wizard_Step1_Subtitle}"
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,12"/>

                        <!-- Prerequisite note — the single most actionable piece of advice.
                             Users regularly size the region against a one-liner and then
                             report "translation cut off" when a quest NPC speaks in
                             3 lines. Tell them to size against the long case up front. -->
                        <Border Background="#FFF7ED" CornerRadius="6" Padding="12,8" Margin="0,0,0,10">
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#9A3412" TextAlignment="Center">
                                <Run x:Name="RunStep1TipPrefix" FontWeight="SemiBold" Text="Tip:"/>
                                <Run x:Name="RunStep1TipBody" Text="Start a quest with an NPC who speaks in 3+ lines, then draw the region a little bigger than that longest line. Short dialogues still fit; long ones won't get clipped."/>
                            </TextBlock>
                        </Border>

                        <!-- Display-mode prerequisite. Exclusive fullscreen disables the
                             Windows desktop compositor that every overlay (Discord, Steam,
                             Kaption) draws through. The result is flicker or a missing
                             overlay. We can't fix this without DLL injection — which
                             would invite anti-cheat — so we surface it up front. -->
                        <Border Background="#EFF6FF" CornerRadius="6" Padding="12,8" Margin="0,0,0,10"
                                BorderBrush="#BFDBFE" BorderThickness="1">
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#1E3A8A" TextAlignment="Center">
                                <Run x:Name="RunStep1BorderlessPrefix" FontWeight="SemiBold" Text="Display mode:"/>
                                <Run x:Name="RunStep1BorderlessBody" Text=" Run the game in Borderless or Windowed mode (Alt+Enter inside the game). Exclusive fullscreen makes the subtitle flicker — same reason Discord and Steam overlays struggle there."/>
                            </TextBlock>
                        </Border>

                        <!-- Companion link to the web guide at kaption.one/how-to/region/.
                             Web guide has a real Genshin screenshot with the dialogue
                             region marked up, which is more convincing than the inline
                             schematic below. Keep the schematic anyway so the wizard
                             works offline. -->
                        <TextBlock HorizontalAlignment="Center" Margin="0,0,0,16"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}">
                            <Run x:Name="RunStep1GuidePrefix" Text="Prefer a walkthrough with screenshots? "/>
                            <Hyperlink NavigateUri="https://kaption.one/how-to/region/"
                                       RequestNavigate="Hyperlink_RequestNavigate"
                                       Foreground="{StaticResource AccentBrush}">
                                <Run x:Name="RunStep1GuideLink" Text="Read the full guide"/>
                            </Hyperlink>
                        </TextBlock>

                        <!-- Auto-detect section -->
                        <Border Background="#EFF6FF" CornerRadius="8" Padding="16,12" Margin="0,0,0,0"
                                HorizontalAlignment="Stretch">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                                    <TextBlock Text="&#x1F50D;" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource Wizard_AutoDetectHint}"
                                               FontSize="12" Foreground="#1E40AF" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button x:Name="BtnAutoDetect" Style="{StaticResource ModernButton}"
                                        Height="40" MinWidth="260" HorizontalAlignment="Center"
                                        Click="AutoDetect_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{DynamicResource Wizard_AutoDetectButton}" FontSize="14" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <TextBlock x:Name="AutoDetectStatus" Text=""
                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,6,0,0"
                                           TextWrapping="Wrap" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Divider with "or" -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,12">
                            <Border Width="80" Height="1" Background="#D1D5DB" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Wizard_OrManually}" FontSize="11" Foreground="#9CA3AF" VerticalAlignment="Center"/>
                            <Border Width="80" Height="1" Background="#D1D5DB" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Schematic Diagram -->
                        <Border Background="#1a1a2e" CornerRadius="10" Height="220"
                                HorizontalAlignment="Stretch" ClipToBounds="True">
                            <Grid>
                                <!-- Simulated game UI -->
                                <Canvas>
                                    <!-- Dark gradient overlay at top for atmosphere -->
                                    <Rectangle Canvas.Left="0" Canvas.Top="0"
                                               Width="620" Height="40" Opacity="0.3">
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#000000" Offset="0"/>
                                                <GradientStop Color="Transparent" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>

                                    <!-- Simulated game scene elements (subtle) -->
                                    <Ellipse Canvas.Left="440" Canvas.Top="16" Width="60" Height="60"
                                             Fill="#1e2240" Opacity="0.6"/>
                                    <Ellipse Canvas.Left="470" Canvas.Top="12" Width="50" Height="50"
                                             Fill="#1e2240" Opacity="0.4"/>

                                    <!-- NPC name in gold -->
                                    <TextBlock Canvas.Left="250" Canvas.Top="58"
                                               Text="Paimon"
                                               FontSize="16" FontWeight="SemiBold"
                                               Foreground="#FFD893"/>

                                    <!-- Dialogue box background (subtle) -->
                                    <Rectangle Canvas.Left="120" Canvas.Top="88"
                                               Width="380" Height="60" RadiusX="6" RadiusY="6"
                                               Fill="#0DFFFFFF"/>

                                    <!-- Dialogue text in white -->
                                    <TextBlock Canvas.Left="145" Canvas.Top="100"
                                               Text="{DynamicResource Wizard_SchematicDialogueLine}"
                                               FontSize="15" FontWeight="Normal"
                                               Foreground="#F0F0F0"/>

                                    <!-- Green dashed selection rectangle -->
                                    <Rectangle Canvas.Left="110" Canvas.Top="50"
                                               Width="400" Height="108" RadiusX="4" RadiusY="4"
                                               Stroke="#4CAF50" StrokeThickness="2.5"
                                               StrokeDashArray="6 3"
                                               Fill="Transparent"/>

                                    <!-- Selection label -->
                                    <Border Canvas.Left="418" Canvas.Top="90"
                                            Background="#2A4CAF50" CornerRadius="4" Padding="8,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#x2190;" FontSize="12"
                                                       Foreground="#4CAF50" Margin="0,0,4,0"/>
                                            <TextBlock Text="{DynamicResource Wizard_SchematicSelectLabel}"
                                                       FontSize="12" FontWeight="Medium"
                                                       Foreground="#4CAF50"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Corner markers on selection rect -->
                                    <Rectangle Canvas.Left="106" Canvas.Top="46"
                                               Width="10" Height="10" Fill="#4CAF50" RadiusX="2" RadiusY="2"/>
                                    <Rectangle Canvas.Left="504" Canvas.Top="46"
                                               Width="10" Height="10" Fill="#4CAF50" RadiusX="2" RadiusY="2"/>
                                    <Rectangle Canvas.Left="106" Canvas.Top="152"
                                               Width="10" Height="10" Fill="#4CAF50" RadiusX="2" RadiusY="2"/>
                                    <Rectangle Canvas.Left="504" Canvas.Top="152"
                                               Width="10" Height="10" Fill="#4CAF50" RadiusX="2" RadiusY="2"/>

                                    <!-- Hint at bottom -->
                                    <TextBlock Canvas.Left="120" Canvas.Top="178"
                                               Text="{DynamicResource Wizard_SchematicSizeHint}"
                                               FontSize="11" Foreground="#6B7280"
                                               FontStyle="Italic"/>
                                </Canvas>
                            </Grid>
                        </Border>

                        <!-- Select Button -->
                        <Button x:Name="BtnSelectDialogue" Style="{StaticResource ModernButton}"
                                Height="38" MinWidth="220" Margin="0,20,0,0"
                                HorizontalAlignment="Center"
                                Click="SelectDialogueRegion_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4CC;" FontSize="13" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Wizard_BtnSelectDialogue}" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Status -->
                        <TextBlock x:Name="Step1Status"
                                   Text="{DynamicResource Wizard_Step1_StatusNone}"
                                   FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ============================================================
                 STEP 2: Select Answer Region (Optional)
                 ============================================================ -->
            <Grid x:Name="Step2Panel" Visibility="Collapsed">
                <!-- TEMPORARILY DISABLED NOTICE (remove this Grid + restore Visibility on
                     the ScrollViewer below when answer-translation is re-enabled). -->
                <Grid x:Name="Step2DisabledNotice" Background="White">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                        <TextBlock Text="&#x1F513;" FontSize="48" HorizontalAlignment="Center"
                                   Margin="0,0,0,16" Foreground="#B45309"/>
                        <TextBlock Text="{DynamicResource Wizard_Step2_DisabledHeading}"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock TextWrapping="Wrap" MaxWidth="460"
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   Text="{DynamicResource Wizard_Step2_DisabledBody}"
                                   Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" MaxWidth="460"
                                   FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"
                                   HorizontalAlignment="Center" TextAlignment="Center" FontStyle="Italic"
                                   Text="{DynamicResource Wizard_Step2_DisabledFootnote}"/>
                    </StackPanel>
                </Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Visibility="Collapsed">
                    <StackPanel Margin="40,24,40,8">

                        <!-- Title row with optional badge -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="{DynamicResource Wizard_Step2_Title}"
                                       FontSize="20" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       VerticalAlignment="Center"/>
                            <Border Background="#FEF3C7" CornerRadius="4"
                                    Padding="8,2" Margin="12,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource Wizard_OptionalBadge}" FontSize="10" FontWeight="Bold"
                                           Foreground="#B45309"/>
                            </Border>
                        </StackPanel>

                        <!-- Subtitle -->
                        <TextBlock Text="{DynamicResource Wizard_Step2_Subtitle}"
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,20"/>

                        <!-- Schematic Diagram -->
                        <Border Background="#1a1a2e" CornerRadius="10" Height="220"
                                HorizontalAlignment="Stretch" ClipToBounds="True">
                            <Grid>
                                <Canvas>
                                    <!-- Faded dialogue area (already selected) -->
                                    <Rectangle Canvas.Left="50" Canvas.Top="50"
                                               Width="290" Height="108" RadiusX="4" RadiusY="4"
                                               Stroke="#4CAF50" StrokeThickness="1.5"
                                               StrokeDashArray="6 3"
                                               Opacity="0.35" Fill="Transparent"/>

                                    <!-- Faded NPC name -->
                                    <TextBlock Canvas.Left="140" Canvas.Top="58"
                                               Text="Paimon" FontSize="14"
                                               Foreground="#FFD893" Opacity="0.4"/>

                                    <!-- Faded dialogue -->
                                    <TextBlock Canvas.Left="88" Canvas.Top="95"
                                               Text="{DynamicResource Wizard_SchematicDialogueLine}"
                                               FontSize="12" Foreground="#F0F0F0" Opacity="0.35"/>

                                    <!-- Faded "Dialogue" label -->
                                    <TextBlock Canvas.Left="140" Canvas.Top="138"
                                               Text="{DynamicResource Wizard_SchematicDialogueRegion}" FontSize="10"
                                               Foreground="#4CAF50" Opacity="0.5"
                                               FontStyle="Italic"/>

                                    <!-- Connecting arrow -->
                                    <Line X1="345" Y1="100" X2="375" Y2="100"
                                          Stroke="#6B7280" StrokeThickness="1.5"
                                          StrokeDashArray="3 2" Opacity="0.5"/>
                                    <Polygon Points="375,95 385,100 375,105"
                                             Fill="#6B7280" Opacity="0.5"/>

                                    <!-- Answer choices area -->
                                    <Rectangle Canvas.Left="390" Canvas.Top="40"
                                               Width="200" Height="140" RadiusX="6" RadiusY="6"
                                               Fill="#0AFFFFFF"/>

                                    <!-- Answer option 1 -->
                                    <Border Canvas.Left="402" Canvas.Top="54"
                                            Width="176" Height="28" CornerRadius="4"
                                            Background="#12FFFFFF">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                    Margin="10,0,0,0">
                                            <TextBlock Text="&#x25B8;" Foreground="#90CAF9"
                                                       FontSize="12" Margin="0,0,6,0"/>
                                            <TextBlock Text="{DynamicResource Wizard_SchematicAnswer1}"
                                                       Foreground="#E0E0E0" FontSize="12"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Answer option 2 -->
                                    <Border Canvas.Left="402" Canvas.Top="90"
                                            Width="176" Height="28" CornerRadius="4"
                                            Background="#12FFFFFF">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                    Margin="10,0,0,0">
                                            <TextBlock Text="&#x25B8;" Foreground="#90CAF9"
                                                       FontSize="12" Margin="0,0,6,0"/>
                                            <TextBlock Text="{DynamicResource Wizard_SchematicAnswer2}"
                                                       Foreground="#E0E0E0" FontSize="12"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Answer option 3 -->
                                    <Border Canvas.Left="402" Canvas.Top="126"
                                            Width="176" Height="28" CornerRadius="4"
                                            Background="#12FFFFFF">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                    Margin="10,0,0,0">
                                            <TextBlock Text="&#x25B8;" Foreground="#90CAF9"
                                                       FontSize="12" Margin="0,0,6,0"/>
                                            <TextBlock Text="{DynamicResource Wizard_SchematicAnswer3}"
                                                       Foreground="#E0E0E0" FontSize="12"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Blue dashed selection rectangle around answers -->
                                    <Rectangle Canvas.Left="384" Canvas.Top="34"
                                               Width="212" Height="152" RadiusX="4" RadiusY="4"
                                               Stroke="#2196F3" StrokeThickness="2.5"
                                               StrokeDashArray="6 3"
                                               Fill="Transparent"/>

                                    <!-- Selection label -->
                                    <Border Canvas.Left="70" Canvas.Top="180"
                                            Background="#2A2196F3" CornerRadius="4" Padding="8,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{DynamicResource Wizard_SchematicAnswerLabel}"
                                                       FontSize="12" FontWeight="Medium"
                                                       Foreground="#2196F3"/>
                                            <TextBlock Text=" &#x2192;" FontSize="12"
                                                       Foreground="#2196F3" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Corner markers on selection rect -->
                                    <Rectangle Canvas.Left="380" Canvas.Top="30"
                                               Width="10" Height="10" Fill="#2196F3" RadiusX="2" RadiusY="2"/>
                                    <Rectangle Canvas.Left="592" Canvas.Top="30"
                                               Width="10" Height="10" Fill="#2196F3" RadiusX="2" RadiusY="2"/>
                                    <Rectangle Canvas.Left="380" Canvas.Top="180"
                                               Width="10" Height="10" Fill="#2196F3" RadiusX="2" RadiusY="2"/>
                                    <Rectangle Canvas.Left="592" Canvas.Top="180"
                                               Width="10" Height="10" Fill="#2196F3" RadiusX="2" RadiusY="2"/>
                                </Canvas>
                            </Grid>
                        </Border>

                        <!-- Select Button -->
                        <Button x:Name="BtnSelectAnswer" Style="{StaticResource ModernButton}"
                                Height="38" MinWidth="220" Margin="0,20,0,0"
                                HorizontalAlignment="Center"
                                Click="SelectAnswerRegion_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4CC;" FontSize="13" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource Wizard_BtnSelectAnswer}" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Status -->
                        <TextBlock x:Name="Step2Status"
                                   Text="{DynamicResource Wizard_Step2_StatusNone}"
                                   FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ============================================================
                 STEP 3: Ready to Go
                 ============================================================ -->
            <Grid x:Name="Step3Panel" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="40,24,40,8">

                        <!-- Title -->
                        <TextBlock Text="{DynamicResource Wizard_Step3_Title}"
                                   FontSize="22" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   HorizontalAlignment="Center"/>

                        <!-- Subtitle -->
                        <TextBlock Text="{DynamicResource Wizard_Step3_Subtitle}"
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,20"/>

                        <!-- Summary Card -->
                        <Border Background="White" CornerRadius="8"
                                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                                Padding="20,16" Margin="20,0,20,16">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Wizard_SummaryHeading}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}"
                                           Margin="0,0,0,12"/>

                                <!-- Dialogue region status -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock x:Name="Step3DialogueIcon" Text="&#x2713;"
                                               FontSize="14" FontWeight="Bold"
                                               Foreground="{StaticResource SuccessBrush}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{DynamicResource Wizard_Summary_DialogueLabel}"
                                               FontSize="13" Foreground="{StaticResource TextBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="Step3DialogueStatus" Text="{DynamicResource Wizard_Summary_NotSet}"
                                               FontSize="13"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Answer region status — hidden while the feature is
                                     temporarily disabled (see MainWindow.FeatureAnswerTranslationEnabled).
                                     The x:Name controls still exist so code-behind references in
                                     UpdateSummaryStatus() resolve; only the visible row is collapsed.
                                     Unhide when re-enabling the answer-translation feature. -->
                                <StackPanel Orientation="Horizontal" Visibility="Collapsed">
                                    <TextBlock x:Name="Step3AnswerIcon" Text="&#x2713;"
                                               FontSize="14" FontWeight="Bold"
                                               Foreground="#2196F3"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{DynamicResource Wizard_Summary_AnswerLabel}"
                                               FontSize="13" Foreground="{StaticResource TextBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="Step3AnswerStatus" Text="{DynamicResource Wizard_Summary_Skipped}"
                                               FontSize="13"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Hotkey Reference Card -->
                        <Border Background="White" CornerRadius="8"
                                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                                Padding="20,16" Margin="20,0,20,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="8"
                                                  ShadowDepth="2" Opacity="0.06"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Wizard_ShortcutsHeading}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}"
                                           Margin="0,0,0,12"/>

                                <!-- Hotkey rows -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#F3F4F6"
                                            CornerRadius="4" Padding="8,4"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="Ctrl + Shift + S" FontSize="12"
                                                   FontFamily="Consolas"
                                                   Foreground="{StaticResource TextBrush}"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="&#x2192;"
                                               FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{DynamicResource Shortcut_StartStop}"
                                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#F3F4F6"
                                            CornerRadius="4" Padding="8,4"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="Ctrl + Shift + R" FontSize="12"
                                                   FontFamily="Consolas"
                                                   Foreground="{StaticResource TextBrush}"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="&#x2192;"
                                               FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{DynamicResource Shortcut_ReselectRegion}"
                                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#F3F4F6"
                                            CornerRadius="4" Padding="8,4"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="Ctrl + Q" FontSize="12"
                                                   FontFamily="Consolas"
                                                   Foreground="{StaticResource TextBrush}"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="&#x2192;"
                                               FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{DynamicResource Shortcut_QuickTranslate}"
                                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#F3F4F6"
                                            CornerRadius="4" Padding="8,4"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{DynamicResource Shortcut_BacktickLabel}" FontSize="12"
                                                   FontFamily="Consolas"
                                                   Foreground="{StaticResource TextBrush}"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="&#x2192;"
                                               FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{DynamicResource Shortcut_ForceOCR}"
                                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#F3F4F6"
                                            CornerRadius="4" Padding="8,4"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="Ctrl + Shift + H" FontSize="12"
                                                   FontFamily="Consolas"
                                                   Foreground="{StaticResource TextBrush}"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="&#x2192;"
                                               FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{DynamicResource Shortcut_ShowHide}"
                                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#F3F4F6"
                                            CornerRadius="4" Padding="8,4"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="Ctrl + Shift + D" FontSize="12"
                                                   FontFamily="Consolas"
                                                   Foreground="{StaticResource TextBrush}"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="&#x2192;"
                                               FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{DynamicResource Shortcut_ClickThrough}"
                                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ============================================================
                 STEP 4: Tips & Settings
                 ============================================================ -->
            <Grid x:Name="Step4Panel" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="40,24,40,8">

                        <TextBlock Text="{DynamicResource Wizard_Step4_Title}"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Wizard_Step4_Subtitle}"
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,20"/>

                        <!-- ============================================================
                             INVITED BY A FRIEND? — OPTIONAL (session 26 referrals)
                             Rendered before the account card so a brand-new
                             user sees it first. Hidden once the user submits
                             a valid code OR clicks Skip, via the
                             ReferralCodeAttributedOrSkipped config sentinel,
                             so re-running the wizard doesn't nag.
                             ============================================================ -->
                        <Border x:Name="ReferralCard" Background="White"
                                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="16,14" Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="{DynamicResource Wizard_Referral_Heading}"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource TextTertiaryBrush}"/>
                                    <Border Background="#FEF3C7" CornerRadius="3"
                                            Padding="6,1" Margin="10,0,0,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource Wizard_OptionalBadge}" FontSize="9" FontWeight="Bold"
                                                   Foreground="#B45309"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{DynamicResource Wizard_Referral_Body}"
                                           FontSize="12" TextWrapping="Wrap"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Background="#F3F4F6" CornerRadius="6"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                            Padding="10,6"
                                            VerticalAlignment="Center">
                                        <TextBox x:Name="ReferralCodeBox"
                                                 MaxLength="32"
                                                 BorderThickness="0" Background="Transparent"
                                                 FontSize="14" FontFamily="Consolas"
                                                 CharacterCasing="Upper"
                                                 TextChanged="ReferralCode_TextChanged"/>
                                    </Border>
                                    <Button x:Name="BtnReferralSkip" Grid.Column="1"
                                            Style="{StaticResource SecondaryButton}"
                                            Content="{DynamicResource Wizard_Referral_Skip}"
                                            MinWidth="70" Height="32"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            Click="ReferralSkip_Click"/>
                                    <Button x:Name="BtnReferralSubmit" Grid.Column="2"
                                            Style="{StaticResource ModernButton}"
                                            Content="{DynamicResource Wizard_Referral_Submit}"
                                            MinWidth="90" Height="32"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            IsEnabled="False"
                                            Click="ReferralSubmit_Click"/>
                                </Grid>
                                <TextBlock x:Name="ReferralStatusText"
                                           FontSize="11" TextWrapping="Wrap"
                                           Margin="0,8,0,0"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>

                        <!-- ============================================================
                             Account / licensing info card.
                             Populated at runtime from App.LicenseService.
                             ============================================================ -->
                        <Border x:Name="AccountCard" Background="White"
                                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="16,14" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{DynamicResource Wizard_Account_SignedIn}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               Margin="0,0,0,2"/>
                                    <TextBlock x:Name="AccountEmailText" Text="{DynamicResource Wizard_Account_NotSignedIn}"
                                               FontSize="14" FontWeight="Medium"
                                               Foreground="{StaticResource TextBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="AccountTierText" Text=""
                                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button x:Name="BtnSignOut" Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                        Content="{DynamicResource Wizard_Account_SignOut}" VerticalAlignment="Center"
                                        Click="SignOut_Click"/>
                            </Grid>
                        </Border>

                        <!-- Overlay section -->
                        <Expander IsExpanded="True" Margin="0,0,0,8" Style="{StaticResource ModernExpander}">
                            <Expander.Header>
                                <TextBlock Text="{DynamicResource Wizard_Section_Overlay}" FontSize="13" FontWeight="SemiBold"/>
                            </Expander.Header>
                            <StackPanel Margin="4,8,0,0">
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8">
                                    <Run x:Name="RunTipDragTitle" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Text="Drag to reposition"/>
                                    <Run x:Name="RunTipDragBody" Text=" — Click and drag the subtitle box to move it. Your position is saved automatically."/>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8">
                                    <Run x:Name="RunTipClickThroughTitle" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Text="Click-through"/>
                                    <Run x:Name="RunTipClickThroughBody" Text=" — Press Ctrl+Shift+D to let clicks pass through the subtitle box (useful during combat)."/>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                    <Run x:Name="RunTipFontTitle" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Text="Font &amp; size"/>
                                    <Run x:Name="RunTipFontBody" Text=" — Customize in the Appearance tab. You can also adjust max width and height for the subtitle box."/>
                                </TextBlock>
                            </StackPanel>
                        </Expander>

                        <!-- Translation section -->
                        <Expander IsExpanded="True" Margin="0,0,0,8" Style="{StaticResource ModernExpander}">
                            <Expander.Header>
                                <TextBlock Text="{DynamicResource Wizard_Section_Translation}" FontSize="13" FontWeight="SemiBold"/>
                            </Expander.Header>
                            <StackPanel Margin="4,8,0,0">
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8">
                                    <Run x:Name="RunTipAnswerTitle" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Text="Answer translation"/>
                                    <Run x:Name="RunTipAnswerBody" Text=" — Enable in Settings &gt; Options to translate player dialogue choices. Requires an answer region set up in the Regions tab."/>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8">
                                    <Run x:Name="RunTipPlayerNameTitle" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Text="Player name"/>
                                    <Run x:Name="RunTipPlayerNameBody" Text=" — Set your character name in Settings &gt; Options so every dialogue line uses it. If you skip this, Kaption falls back to &quot;Traveler&quot; everywhere."/>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                    <Run x:Name="RunTipPredictionTitle" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Text="Dialogue prediction"/>
                                    <Run x:Name="RunTipPredictionBody" Text=" — The app predicts the next dialogue line from game data and shows translations ahead of the scan."/>
                                </TextBlock>
                            </StackPanel>
                        </Expander>

                        <!-- Regions & OCR section — expanded by default to match
                             the Overlay and Translation sections above. Previously
                             collapsed, which hid the "Show Region" verify button
                             and the manual-region workaround a lot of users need
                             on first setup. If the text grows long enough to
                             feel cramped, revisit the default. -->
                        <Expander IsExpanded="True" Margin="0,0,0,8" Style="{StaticResource ModernExpander}">
                            <Expander.Header>
                                <TextBlock Text="{DynamicResource Wizard_Section_Regions}" FontSize="13" FontWeight="SemiBold"/>
                            </Expander.Header>
                            <StackPanel Margin="4,8,0,0">
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8">
                                    <Run x:Name="RunTipShowRegionsTitle" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Text="Show regions"/>
                                    <Run x:Name="RunTipShowRegionsBody" Text=" — Use the &quot;Show Region&quot; button in the Regions tab to verify your capture areas are positioned correctly."/>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8">
                                    <Run x:Name="RunTipOcrTuningTitle" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Text="Performance tuning"/>
                                    <Run x:Name="RunTipOcrTuningBody" Text=" — Adjust scan speed and stability window in the Settings tab. Lower values = faster but uses more CPU. Higher = more stable results."/>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                    <Run x:Name="RunTipManualTitle" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Text="Manual region"/>
                                    <Run x:Name="RunTipManualBody" Text=" — If auto-detect doesn't work well, use &quot;Select Region&quot; to draw the capture area manually. Fine-tune with the X/Y/W/H fields."/>
                                </TextBlock>
                            </StackPanel>
                        </Expander>

                        <!-- Start Translating Button -->
                        <Button x:Name="BtnStartTranslating" Style="{StaticResource ModernButton}"
                                Height="44" MinWidth="300" Margin="0,20,0,0"
                                HorizontalAlignment="Stretch"
                                Click="StartTranslating_Click">
                            <TextBlock Text="{DynamicResource Wizard_StartTranslating}" FontSize="15" FontWeight="SemiBold"/>
                        </Button>

                        <!-- Secondary links: Open Settings · Send feedback.
                             Feedback entry point is intentionally subtle — a
                             text link, not a CTA button. One path in, no
                             nagging; the user sees it once per setup and
                             only uses it when they have something to say. -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,10,0,0">
                            <Button x:Name="BtnOpenSettings" Cursor="Hand"
                                    Click="OpenSettings_Click"
                                    Background="Transparent" BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <TextBlock x:Name="linkText"
                                                   Text="{DynamicResource Wizard_OpenSettings}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   TextDecorations="Underline"
                                                   Cursor="Hand"/>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="linkText" Property="Foreground"
                                                        Value="{StaticResource AccentHoverBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <TextBlock Text="  ·  "
                                       FontSize="12"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       VerticalAlignment="Center"/>

                            <Button x:Name="BtnSendFeedback" Cursor="Hand"
                                    Click="SendFeedback_Click"
                                    Background="Transparent" BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <TextBlock x:Name="linkText"
                                                   Text="{DynamicResource Wizard_SendFeedback}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   TextDecorations="Underline"
                                                   Cursor="Hand"/>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="linkText" Property="Foreground"
                                                        Value="{StaticResource AccentHoverBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ================================================================
             ROW 2: NAVIGATION BAR
             ================================================================ -->
        <Border Grid.Row="2" Background="White"
                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,0"
                Padding="32,12,32,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left side: Back + Skip -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button x:Name="BtnBack" Style="{StaticResource SecondaryButton}"
                            Content="{DynamicResource Wizard_Back}" Visibility="Collapsed"
                            Click="NavigateBack" Margin="0,0,8,0"/>
                    <Button x:Name="BtnSkip" Style="{StaticResource SecondaryButton}"
                            Content="{DynamicResource Wizard_SkipNav}" Visibility="Visible"
                            Click="NavigateNext"/>
                </StackPanel>

                <!-- Right side: Next -->
                <Button x:Name="BtnNext" Grid.Column="1" Style="{StaticResource ModernButton}"
                        Content="{DynamicResource Wizard_Next}"
                        Click="NavigateNext"/>
            </Grid>
        </Border>
    </Grid>
</Window>
