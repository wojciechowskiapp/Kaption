<Window x:Class="GI_Subtitles.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GI_Subtitles.Views"
        xmlns:rendering="clr-namespace:GI_Subtitles.Services.Rendering"
        mc:Ignorable="d"
        WindowStyle="None" Height="20"  ShowInTaskbar="False" Topmost="True" Background="Transparent" AllowsTransparency="True" MouseDown="Window_MouseDown">
    <Grid Background="Transparent">
        <!-- Default subtitle container with semi-transparent background -->
        <Border x:Name="SubtitleBackground"
                Background="#B0000000"
                CornerRadius="8"
                Padding="16,8,16,12"
                Cursor="Hand"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <!-- Header (NPC name) above dialog text — now with outline -->
                <rendering:OutlinedTextBlock x:Name="HeaderText"
                    TextWrapping="Wrap" Foreground="#FFD893"
                    TextAlignment="Center" FontWeight="Bold" FontSize="14"
                    StrokeBrush="Black" StrokeThickness="2"
                    Margin="0,0,0,4" Visibility="Collapsed"/>
                <!-- Main subtitle text — outlined for readability -->
                <rendering:OutlinedTextBlock x:Name="SubtitleText"
                    TextWrapping="Wrap"
                    Foreground="White"
                    TextAlignment="Center"
                    FontWeight="Bold"
                    StrokeBrush="Black"
                    StrokeThickness="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>
                <!-- Answer separator — thin line between main translation and answers -->
                <Border x:Name="AnswerSeparator" Height="1" Background="#30FFFFFF"
                        Margin="0,8,0,6" Visibility="Collapsed"/>
                <!-- Translated dialogue answers -->
                <rendering:OutlinedTextBlock x:Name="AnswerText"
                    TextWrapping="Wrap" Foreground="#B0E8D8A0"
                    TextAlignment="Left" FontWeight="Normal" FontSize="13"
                    StrokeBrush="#50000000" StrokeThickness="1.2"
                    Visibility="Collapsed"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
