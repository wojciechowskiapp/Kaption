<?xml version="1.0" encoding="utf-8"?>
<!--
  Net8 migration (2026-04-23): this file is now the log4net sidecar only.
  GC settings moved to runtimeconfig.template.json. Binding redirects
  deleted (inert on .NET 8 — Core+ assembly loader ignores them). <startup>
  supportedRuntime deleted. <uri> schemeSettings deleted (default Uri
  behavior on net8 matches what we need for R2 URLs).
-->
<configuration>
  <configSections>
    <section name="log4net" type="log4net.Config.Log4NetConfigurationSectionHandler, log4net" />
  </configSections>
  <log4net>
    <appender name="LogFileAppender" type="log4net.Appender.RollingFileAppender">
      <file type="log4net.Util.PatternString" value="%envFolderPath{ApplicationData}\Kaption\app.log" />
      <appendToFile value="true" />
      <datePattern value="yyyyMMdd-HH:mm:ss" />
      <rollingStyle value="Size" />
      <maxSizeRollBackups value="1" />
      <maximumFileSize value="10MB" />
      <encoding value="utf-8" />
      <!--
        immediateFlush=true disables the buffer and forces every log line to disk
        before the call returns. Slight perf cost (~microseconds per line) in
        exchange for: when the process dies from a native crash / stack overflow /
        AccessViolation that our managed exception handlers can't observe, the
        last few log lines before the crash are still on disk for diagnosis.
      -->
      <immediateFlush value="true" />
      <layout type="log4net.Layout.PatternLayout">
        <footer value="" />
        <conversionPattern value="[%-5level] Time：%date Content：%message%newline" />
      </layout>
    </appender>
    <root>
      <!--
        INFO is the shipped default. DEBUG is a developer-only noise level
        (OCR tick timings, per-frame capture state, pixel-change ratios) and
        was accidentally the production default until session 26.
        Users who want verbose logs can override without editing this file
        by setting `LogLevel=DEBUG` (or TRACE/ALL) in
        %APPDATA%\Kaption\Config.json — Logger.ApplyConfiguredLevel reads
        it at startup and bumps the root level accordingly.
      -->
      <level value="INFO" />
      <appender-ref ref="LogFileAppender" />
    </root>
  </log4net>
</configuration>
